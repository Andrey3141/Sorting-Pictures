import 'package:flutter/material.dart';
import 'package:file_picker/file_picker.dart';
import 'dart:io';
import 'dart:async';

import 'database/face_database.dart';
import 'services/face_recognizer.dart';
import 'services/photo_sorter.dart';
import 'widgets/animated_button.dart';
import 'widgets/face_card.dart';
import 'screens/training_dialog.dart';
import 'workers/image_processor.dart';
import 'workers/batch_sorter_worker.dart';

void main() {
  runApp(const FaceOrganizerApp());
}

class FaceOrganizerApp extends StatelessWidget {
  const FaceOrganizerApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Face Organizer AI',
      theme: ThemeData.dark(),
      home: const MainWindow(),
      debugShowCheckedModeBanner: false,
    );
  }
}

class MainWindow extends StatefulWidget {
  const MainWindow({super.key});

  @override
  State<MainWindow> createState() => _MainWindowState();
}

class _MainWindowState extends State<MainWindow> {
  late FaceDatabase db;
  late FaceRecognizer recognizer;
  late PhotoSorter sorter;
  
  String? currentImagePath;
  List<Map<String, dynamic>> currentFaceData = [];
  String statsText = "Готов к работе";
  final List<String> logMessages = [];
  final ScrollController logScrollController = ScrollController();
  
  bool showProgress = false;
  int progressValue = 0;
  int progressMax = 0;
  
  StreamSubscription? processorSubscription;
  StreamSubscription? batchSubscription;
  
  final String sortedPhotosDir = "sorted_photos";

  @override
  void initState() {
    super.initState();
    initializeApp();
  }
  
  void initializeApp() async {
    db = FaceDatabase();
    recognizer = FaceRecognizer(db);
    sorter = PhotoSorter(recognizer, db, sortedPhotosDir);
    
    await recognizer.loadKnownFaces();
    await updateStats();
    logMessage("✅ Программа запущена");
    setState(() {});
  }
  
  Future<void> updateStats() async {
    int knownCount = await recognizer.getKnownFacesCount();
    setState(() {
      statsText = "📚 БАЗА: $knownCount человек";
    });
  }
  
  void logMessage(String message) {
    String timestamp = DateTime.now().toString().substring(11, 19);
    setState(() {
      logMessages.add("[${timestamp}] $message");
    });
    WidgetsBinding.instance.addPostFrameCallback((_) {
      if (logScrollController.hasClients) {
        logScrollController.animateTo(
          logScrollController.position.maxScrollExtent,
          duration: const Duration(milliseconds: 100),
          curve: Curves.easeOut,
        );
      }
    });
  }
  
  Future<void> uploadImage() async {
    FilePickerResult? result = await FilePicker.platform.pickFiles(type: FileType.image);
    if (result != null && result.files.single.path != null) {
      String path = result.files.single.path!;
      setState(() => currentImagePath = path);
      await processImage(path);
    }
  }
  
  Future<void> processImage(String imagePath) async {
    setState(() {
      currentFaceData.clear();
      showProgress = true;
    });
    
    logMessage("🔍 Анализ: ${imagePath.split('/').last}");
    
    final results = await recognizer.processImage(imagePath, (faceData) {
      setState(() => currentFaceData.add(faceData));
    });
    
    setState(() => showProgress = false);
    
    if (results.isEmpty) {
      logMessage("⚠️ Лица не обнаружены");
    } else {
      logMessage("✅ Найдено ${results.length} лиц");
    }
  }
  
  Future<void> sortCurrentImage() async {
    if (currentImagePath == null) return;
    logMessage("🚀 Сортировка...");
    await sorter.sortPhoto(currentImagePath!);
    logMessage("✅ Готово");
  }
  
  Future<void> batchSortFolder() async {
    String? folder = await FilePicker.platform.getDirectoryPath();
    if (folder == null) return;
    logMessage("📂 Сортировка папки: $folder");
    await sorter.sortFolder(folder, null);
    logMessage("✅ Готово");
  }
  
  void openTrainingPanel() async {
    await showDialog(
      context: context,
      builder: (context) => TrainingDialog(db: db, recognizer: recognizer),
    );
    await recognizer.loadKnownFaces();
    await updateStats();
  }
  
  void clearAll() {
    setState(() {
      currentFaceData.clear();
      currentImagePath = null;
    });
    logMessage("🗑️ Очищено");
  }
  
  Future<void> openSortedFolder() async {
    logMessage("📂 Папка: $sortedPhotosDir");
  }
  
  void quickLabelFace(Map<String, dynamic> faceData, int index) async {
    TextEditingController controller = TextEditingController();
    String? name = await showDialog<String>(
      context: context,
      builder: (BuildContext ctx) {
        return AlertDialog(
          title: const Text("Добавить человека"),
          content: TextField(
            controller: controller,
            autofocus: true,
            decoration: const InputDecoration(hintText: "Введите имя"),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.pop(ctx),
              child: const Text("Отмена"),
            ),
            TextButton(
              onPressed: () => Navigator.pop(ctx, controller.text),
              child: const Text("Добавить"),
            ),
          ],
        );
      },
    );
    
    if (name != null && name.isNotEmpty) {
      await db.addFace(name, faceData["embedding"]);
      await recognizer.loadKnownFaces();
      await updateStats();
      setState(() {
        currentFaceData[index]["name"] = name;
        currentFaceData[index]["is_known"] = true;
      });
      logMessage("✅ Добавлен: $name");
    }
    controller.dispose();
  }
  
  Future<void> markAsFalsePositive(Map<String, dynamic> faceData, int index) async {
    await recognizer.markAsFalsePositive(currentImagePath!, faceData);
    setState(() => currentFaceData.removeAt(index));
    logMessage("❌ Помечено как НЕ ЛИЦО");
  }
  
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: Container(
        color: const Color(0xFF0f0f1a),
        child: Column(
          children: [
            SingleChildScrollView(
              scrollDirection: Axis.horizontal,
              child: Padding(
                padding: const EdgeInsets.all(8),
                child: Row(
                  children: [
                    AnimatedButton(text: "📤 Загрузить", color: Colors.green, onPressed: uploadImage),
                    const SizedBox(width: 8),
                    AnimatedButton(text: "📁 Сорт. фото", color: Colors.blue, onPressed: sortCurrentImage),
                    const SizedBox(width: 8),
                    AnimatedButton(text: "📂 Сорт. папку", color: Colors.purple, onPressed: batchSortFolder),
                    const SizedBox(width: 8),
                    AnimatedButton(text: "🎓 Обучение", color: Colors.orange, onPressed: openTrainingPanel),
                    const SizedBox(width: 8),
                    AnimatedButton(text: "📂 Открыть", color: Colors.cyan, onPressed: openSortedFolder),
                    const SizedBox(width: 8),
                    AnimatedButton(text: "🗑️ Очистить", color: Colors.red, onPressed: clearAll),
                    const SizedBox(width: 8),
                    Text(statsText, style: const TextStyle(color: Colors.green)),
                  ],
                ),
              ),
            ),
            const Divider(color: Colors.green),
            Expanded(
              child: currentImagePath == null
                  ? const Center(child: Text("📸 НАЖМИТЕ ЗАГРУЗИТЬ"))
                  : Image.file(File(currentImagePath!), fit: BoxFit.contain),
            ),
            if (currentFaceData.isNotEmpty)
              SizedBox(
                height: 200,
                child: ListView.builder(
                  scrollDirection: Axis.horizontal,
                  itemCount: currentFaceData.length,
                  itemBuilder: (_, i) => FaceCard(
                    faceData: currentFaceData[i],
                    onAddName: () => quickLabelFace(currentFaceData[i], i),
                    onMarkAsNotFace: () => markAsFalsePositive(currentFaceData[i], i),
                  ),
                ),
              ),
            if (showProgress) const LinearProgressIndicator(),
            Expanded(
              child: Container(
                margin: const EdgeInsets.all(8),
                decoration: BoxDecoration(border: Border.all(color: Colors.green)),
                child: ListView.builder(
                  controller: logScrollController,
                  itemCount: logMessages.length,
                  itemBuilder: (_, i) => Text(logMessages[i], style: const TextStyle(color: Colors.green, fontSize: 10)),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }
}
